{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "@github_token"
      },
      "description": "GitHub repository management, PR reviews, issue tracking"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "description": "Local file system access and manipulation"
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "description": "HTTP/HTTPS requests, API calls, web scraping"
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "./memory/.mcp-memory-store.json"
      },
      "description": "Official MCP knowledge graph memory — entities, relations, observations persisted to memory/.mcp-memory-store.json and committed to GitHub"
    },
    "memory-service": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-memory-service"
      ],
      "env": {
        "MCP_MEMORY_STORAGE_PATH": "./memory/.memory-service-db",
        "MCP_MEMORY_BACKEND": "sqlite-vec"
      },
      "description": "Advanced semantic memory with embeddings, knowledge graph, and auto-consolidation (doobidoo/mcp-memory-service)"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Extended thinking for complex problem decomposition"
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_SEARCH_API_KEY": "@brave_search_key"
      },
      "description": "Web search for lead research and market analysis"
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "env": {
        "DATABASE_URL": "@database_url"
      },
      "description": "PostgreSQL database access (when DATABASE_URL is configured)"
    }
  },
  "environmentVariables": {
    "@github_token": "GITHUB_PERSONAL_ACCESS_TOKEN",
    "@brave_search_key": "BRAVE_SEARCH_API_KEY",
    "@database_url": "DATABASE_URL"
  },
  "toolOverrides": {
    "description": "Agent-specific tool configurations",
    "agents": {
      "apex": {
        "allowedTools": [
          "Agent",
          "Read",
          "Glob",
          "Grep",
          "Bash",
          "mcp__github__*",
          "mcp__filesystem__*",
          "mcp__fetch__*",
          "mcp__brave-search__*",
          "mcp__memory__*",
          "mcp__memory-service__*",
          "mcp__sequential-thinking__*"
        ]
      },
      "nova": {
        "allowedTools": [
          "Read",
          "Grep",
          "Bash",
          "mcp__browser__*",
          "mcp__fetch__*",
          "mcp__brave-search__*",
          "mcp__memory__*",
          "mcp__memory-service__*"
        ]
      },
      "meridian": {
        "allowedTools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "mcp__browser__*",
          "mcp__fetch__*",
          "mcp__brave-search__*",
          "mcp__memory__*"
        ]
      },
      "prism": {
        "allowedTools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "Glob",
          "Grep",
          "mcp__memory__*"
        ]
      },
      "vertex": {
        "allowedTools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "Glob",
          "Grep",
          "mcp__github__*",
          "mcp__memory__*"
        ]
      },
      "nexus": {
        "allowedTools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "Glob",
          "Grep",
          "mcp__github__*",
          "mcp__postgres__*",
          "mcp__memory__*"
        ]
      },
      "sentinel": {
        "allowedTools": [
          "Read",
          "Glob",
          "Grep",
          "Bash",
          "mcp__browser__*",
          "mcp__memory__*"
        ],
        "deniedTools": [
          "Write",
          "Edit"
        ]
      },
      "compass": {
        "allowedTools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "mcp__fetch__*",
          "mcp__browser__*",
          "mcp__memory__*"
        ]
      }
    }
  }
}
